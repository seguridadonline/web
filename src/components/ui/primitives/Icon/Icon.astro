---
import { cn } from '@/lib/cn';
import * as LucideIcons from 'lucide-astro';

interface Props {
  name: string;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
  strokeWidth?: number;
}

const { name, size = 'md', class: className, strokeWidth = 2 } = Astro.props;

const sizes = {
  xs: 'w-3 h-3',
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
  xl: 'w-8 h-8',
};

// Convertimos el nombre (ej: "shield-check") a PascalCase (ej: "ShieldCheck")
const toPascalCase = (str: string) => 
  str.replace(/(^\w|-\w)/g, (match) => match.replace('-', '').toUpperCase());

const iconName = toPascalCase(name) as keyof typeof LucideIcons;
const SelectedIcon = LucideIcons[iconName];
---

{SelectedIcon ? (
  <SelectedIcon 
    class={cn(sizes[size], 'shrink-0', className)} 
    stroke-width={strokeWidth}
  />
) : (
  <span class="text-red-500 font-bold">X</span>
)}