---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { Image } from 'astro:assets';
import binanceQr from '@/assets/Binance.png';
import { getLocaleFromPath } from '@/i18n/config';
import { es } from '@/i18n/translations/es.ts';
import { en } from '@/i18n/translations/en.ts';
import { fr } from '@/i18n/translations/fr.ts';

const locale = getLocaleFromPath(Astro.url.pathname);
const dictionaries: Record<string, any> = { es, en, fr };
const currentLang = dictionaries[locale] || dictionaries.es;

const donateData = currentLang.donate;
---

<PageLayout
  title={donateData.meta.title}
  description={donateData.meta.description}
>
  <section class="relative pt-12 pb-16 md:pt-20 md:pb-24 overflow-hidden border-b border-border bg-secondary/5">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[40rem] h-[20rem] bg-brand-500/10 rounded-full blur-[100px] -z-10"></div>
    
    <div class="container mx-auto px-6 text-center z-10 relative max-w-4xl">
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-brand-500/10 text-brand-500 rounded-2xl shadow-sm border border-brand-500/20">
          <Icon name="heart-handshake" class="w-8 h-8" />
        </div>
      </div>
      
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-secondary text-foreground text-sm font-semibold border border-border shadow-sm">
          <Icon name="heart" class="w-4 h-4 text-brand-500" />
          {donateData.hero.badge}
        </div>
      </div>
      
      <h1 class="text-3xl font-extrabold tracking-tight md:text-5xl lg:text-[3.25rem] leading-tight text-foreground mb-6">
        {donateData.hero.title}
      </h1>
      
      <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto">
        {donateData.hero.description}
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
        
        <div class="lg:w-1/2 space-y-8">
          <div class="bg-background rounded-3xl p-6 md:p-8 border border-border shadow-sm hover:border-brand-500/30 transition-all">
            <h2 class="text-xl md:text-2xl font-bold mb-8 text-foreground flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-secondary flex items-center justify-center shrink-0">
                <Icon name="search" class="w-5 h-5 text-foreground-muted" />
              </div>
              {donateData.transparency.title}
            </h2>
            <div class="space-y-6">
              <div class="flex items-start gap-4 p-4 rounded-2xl bg-secondary/20 border border-border">
                <div class="mt-1 w-10 h-10 rounded-xl bg-background flex items-center justify-center shadow-sm shrink-0">
                  <Icon name="server" class="w-5 h-5 text-foreground-muted" />
                </div>
                <div>
                  <h3 class="text-base md:text-lg font-bold text-foreground mb-1">{donateData.transparency.items[0].title}</h3>
                  <p class="text-sm md:text-base text-foreground-muted leading-relaxed">{donateData.transparency.items[0].description}</p>
                </div>
              </div>
              <div class="flex items-start gap-4 p-4 rounded-2xl bg-secondary/20 border border-border">
                <div class="mt-1 w-10 h-10 rounded-xl bg-background flex items-center justify-center shadow-sm shrink-0">
                  <Icon name="clock" class="w-5 h-5 text-foreground-muted" />
                </div>
                <div>
                  <h3 class="text-base md:text-lg font-bold text-foreground mb-1">{donateData.transparency.items[1].title}</h3>
                  <p class="text-sm md:text-base text-foreground-muted leading-relaxed">{donateData.transparency.items[1].description}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-brand-500/5 border border-brand-500/20 p-6 md:p-8 rounded-3xl relative overflow-hidden shadow-sm transition-colors hover:border-brand-500/40">
            <Icon name="shield-check" class="absolute -right-4 -bottom-4 w-32 h-32 text-brand-500/5 pointer-events-none" />
            <h3 class="text-lg md:text-xl font-bold mb-4 text-foreground relative z-10 flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center shrink-0">
                <Icon name="info" class="w-5 h-5 text-brand-500" />
              </div>
              {donateData.disclaimer.title}
            </h3>
            <p class="text-foreground-muted leading-relaxed relative z-10 text-sm md:text-base" set:html={donateData.disclaimer.description}></p>
          </div>
        </div>

        <div class="lg:w-1/2 w-full">
          <div class="bg-background p-6 md:p-8 rounded-3xl border border-border shadow-sm hover:border-brand-500/30 transition-all">
            <h2 class="text-xl md:text-2xl font-bold mb-8 text-foreground flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-secondary flex items-center justify-center shrink-0">
                <Icon name="wallet" class="w-5 h-5 text-foreground-muted" />
              </div>
              {donateData.methods.title}
            </h2>

            <div class="space-y-6">
              
              <div class="bg-secondary/20 border border-border rounded-2xl p-5 md:p-6 shadow-sm transition-colors hover:border-brand-500/40">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="text-lg md:text-xl font-bold flex items-center gap-3 text-foreground">
                    <div class="w-8 h-8 bg-[#FCD535] rounded-full flex items-center justify-center shadow-sm">
                      <Icon name="wallet" class="w-4 h-4 text-black" />
                    </div>
                    {donateData.methods.binance.title}
                  </h3>
                </div>
                <p class="text-foreground-muted text-sm md:text-base mb-6 leading-relaxed">
                  {donateData.methods.binance.description}
                </p>

                <div class="flex flex-col sm:flex-row gap-6 items-center bg-background p-4 md:p-5 rounded-2xl border border-border">
                  <div class="w-32 h-32 shrink-0 bg-white border border-border rounded-xl flex items-center justify-center p-2 shadow-sm overflow-hidden">
                    <Image 
                      src={binanceQr} 
                      alt={donateData.methods.binance.qrAlt || "Binance QR Code"} 
                      class="w-full h-full object-contain"
                    />
                  </div>

                  <div class="flex-1 w-full space-y-2">
                    <label class="text-sm font-semibold text-foreground">{donateData.methods.binance.payIdLabel}</label>
                    <div class="flex bg-secondary/50 border border-border rounded-xl overflow-hidden focus-within:ring-2 focus-within:ring-brand-500/50 focus-within:border-brand-500 transition-all">
                      <input 
                        type="text" 
                        id="binance-id" 
                        readonly 
                        value={donateData.methods.binance.payIdValue} 
                        class="w-full bg-transparent px-4 py-3 text-foreground font-mono text-sm focus:outline-none"
                      />
                      <button 
                        id="copy-btn" 
                        class="px-4 py-3 bg-brand-500 text-on-brand hover:bg-brand-600 transition-colors font-semibold text-sm flex items-center gap-2 shrink-0"
                      >
                        <Icon name="copy" class="w-4 h-4" />
                        <span id="copy-text" class="hidden sm:inline">{donateData.methods.binance.copyBtn}</span>
                      </button>
                    </div>
                  </div>
                </div>
              </div>

              <div class="bg-secondary/10 border border-border border-dashed rounded-2xl p-5 md:p-6 opacity-60 grayscale hover:grayscale-0 transition-all duration-300">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="text-base md:text-lg font-bold flex items-center gap-3 text-foreground-muted">
                    <div class="w-8 h-8 bg-background border border-border rounded-full flex items-center justify-center shadow-sm">
                      <Icon name="coffee" class="w-4 h-4 text-foreground-muted" />
                    </div>
                    {donateData.methods.kofi.title}
                  </h3>
                  <span class="text-xs font-bold uppercase tracking-wider bg-background border border-border text-foreground-muted px-3 py-1.5 rounded-full shadow-sm">
                    {donateData.methods.kofi.badge}
                  </span>
                </div>
                <p class="text-foreground-muted text-sm leading-relaxed">
                  {donateData.methods.kofi.description}
                </p>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script define:vars={{ copiedText: donateData.methods.binance.copiedBtn, copyText: donateData.methods.binance.copyBtn }}>
    function initCopyBtn() {
      const copyBtn = document.getElementById('copy-btn');
      const input = document.getElementById('binance-id');
      const textSpan = document.getElementById('copy-text');
      
      if (!copyBtn || !input || !textSpan) return;

      copyBtn.addEventListener('click', () => {
        input.select();
        input.setSelectionRange(0, 99999);
        navigator.clipboard.writeText(input.value);

        textSpan.innerText = copiedText;
        copyBtn.classList.add('bg-green-600');
        
        setTimeout(() => {
          textSpan.innerText = copyText;
          copyBtn.classList.remove('bg-green-600');
        }, 2000);
      });
    }

    initCopyBtn();
    document.addEventListener('astro:page-load', initCopyBtn);
  </script>
</PageLayout>