---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

import { getLocaleFromPath } from '@/i18n/config';

import { es } from '@/i18n/translations/es.ts';
import { en } from '@/i18n/translations/en.ts';
import { fr } from '@/i18n/translations/fr.ts';

const locale = getLocaleFromPath(Astro.url.pathname);
const dictionaries: Record<string, any> = { es, en, fr };
const currentLang = dictionaries[locale] || dictionaries.es;

const contactData = currentLang.contact;

const ruleStyles = [
  { icon: "x", color: "text-red-500" },
  { icon: "x", color: "text-red-500" },
  { icon: "check", color: "text-brand-500" }
];
---

<PageLayout
  title={contactData.meta.title}
  description={contactData.meta.description}
>
  <section class="relative pt-12 pb-16 md:pt-20 md:pb-24 overflow-hidden border-b border-border bg-secondary/5">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-[30rem] h-[30rem] bg-brand-500/10 rounded-full blur-[100px] -z-10"></div>
    
    <div class="container mx-auto px-6 text-center z-10 relative max-w-4xl">
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-brand-500/10 text-brand-500 rounded-2xl shadow-sm border border-brand-500/20">
          <Icon name="mail" class="w-8 h-8" />
        </div>
      </div>
      
      <h1 class="text-3xl font-extrabold tracking-tight md:text-5xl lg:text-[3.25rem] leading-tight text-foreground mb-6">
        {contactData.hero.title}
      </h1>
      
      <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto" set:html={contactData.hero.description}></p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <div class="lg:w-3/5">
          <div class="bg-background border border-border rounded-3xl p-6 md:p-10 shadow-sm relative overflow-hidden transition-all hover:border-brand-500/30">
            <div class="absolute top-0 right-0 w-40 h-40 bg-brand-500/5 rounded-full blur-[60px] -z-10"></div>
            
            <h2 class="text-2xl font-bold mb-8 text-foreground flex items-center gap-2">
              <Icon name="send" class="w-5 h-5 text-brand-500" />
              {contactData.form.title}
            </h2>
            
            <form id="contactForm" action="https://script.google.com/macros/s/AKfycbwrH20Dc6HTsWOf4UIaJm4-euGtGwnCNvawSaSSM3YC_biOv5WxfXi4sw4v5QLdk-ie/exec" method="POST" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div class="space-y-2">
                  <label for="nombre" class="text-sm font-semibold text-foreground">{contactData.form.name.label}</label>
                  <input 
                    type="text" 
                    id="nombre" 
                    name="nombre" 
                    placeholder={contactData.form.name.placeholder}
                    class="w-full bg-secondary/30 border border-border rounded-xl px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-colors focus:bg-background"
                  />
                </div>
                
                <div class="space-y-2">
                  <label for="email" class="text-sm font-semibold text-foreground">{contactData.form.email.label} <span class="text-brand-500">*</span></label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required 
                    placeholder={contactData.form.email.placeholder}
                    class="w-full bg-secondary/30 border border-border rounded-xl px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-colors focus:bg-background"
                  />
                  <p class="text-xs text-foreground-muted flex items-center gap-1 mt-1">
                    <Icon name="lock" class="w-3 h-3" />
                    {contactData.form.email.hint}
                  </p>
                </div>
              </div>

              <div class="space-y-2">
                <label for="asunto" class="text-sm font-semibold text-foreground">{contactData.form.subject.label} <span class="text-brand-500">*</span></label>
                <div class="relative">
                  <select 
                    id="asunto" 
                    name="asunto" 
                    required
                    class="w-full bg-secondary/30 border border-border rounded-xl px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-colors appearance-none focus:bg-background cursor-pointer"
                  >
                    <option value="" disabled selected>{contactData.form.subject.placeholder}</option>
                    {contactData.form.subject.options.map((option: any) => (
                      <option value={option.value}>{option.label}</option>
                    ))}
                  </select>
                  <Icon name="chevron-down" class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-foreground-muted pointer-events-none" />
                </div>
              </div>

              <div class="space-y-2">
                <label for="url" class="text-sm font-semibold text-foreground">{contactData.form.url.label}</label>
                <input 
                  type="url" 
                  id="url" 
                  name="url" 
                  placeholder={contactData.form.url.placeholder}
                  class="w-full bg-secondary/30 border border-border rounded-xl px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-colors focus:bg-background font-mono text-sm"
                />
              </div>

              <div class="space-y-2">
                <label for="mensaje" class="text-sm font-semibold text-foreground">{contactData.form.message.label} <span class="text-brand-500">*</span></label>
                <textarea 
                  id="mensaje" 
                  name="mensaje" 
                  rows="5" 
                  required
                  placeholder={contactData.form.message.placeholder}
                  class="w-full bg-secondary/30 border border-border rounded-xl px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-brand-500/50 focus:border-brand-500 transition-colors resize-y focus:bg-background"
                ></textarea>
              </div>

<div class="pt-4">
    <Button type="submit" id="submitBtn" size="lg" class="w-full sm:w-auto px-10 shadow-sm">
      {contactData.form.submitBtn}
    </Button>
  </div>
</form>
<div id="formFeedback" class="hidden mt-4 p-4 rounded-xl border text-center"></div>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  const feedback = document.getElementById('formFeedback') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // UI Feedback
    btn.disabled = true;
    btn.innerText = "Enviando...";
    
    try {
      const formData = new FormData(form);
      await fetch(form.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors' // Necesario para Google Apps Script
      });
      
      // Éxito
      feedback.classList.remove('hidden', 'bg-red-500/10', 'border-red-500/20', 'text-red-600');
      feedback.classList.add('bg-green-500/10', 'border-green-500/20', 'text-green-600');
      feedback.innerText = "¡Mensaje enviado correctamente! Te contactaremos pronto.";
      form.reset();
    } catch (error) {
      // Error
      feedback.classList.remove('hidden', 'bg-green-500/10', 'border-green-500/20', 'text-green-600');
      feedback.classList.add('bg-red-500/10', 'border-red-500/20', 'text-red-600');
      feedback.innerText = "Hubo un error al enviar. Por favor, intenta de nuevo o escribe a info@seguridadonline.org";
    } finally {
      btn.disabled = false;
      btn.innerText = "Enviar Reporte";
    }
  });
</script>
          </div>
        </div>

        <div class="lg:w-2/5 space-y-8">
          
          <div class="bg-background rounded-3xl p-6 md:p-8 border border-border shadow-sm">
            <h3 class="text-lg md:text-xl font-bold mb-6 text-foreground">{contactData.sidebar.contact.title}</h3>
            <div class="space-y-4">
              <a href={`mailto:${contactData.sidebar.contact.email.value}`} class="flex items-center gap-4 p-4 rounded-2xl border border-border hover:border-brand-500/40 hover:bg-secondary/10 transition-all group shadow-sm">
                <div class="w-12 h-12 bg-secondary rounded-xl flex items-center justify-center group-hover:bg-brand-500/10 transition-colors shrink-0">
                  <Icon name="mail" class="w-5 h-5 text-foreground-muted group-hover:text-brand-500" />
                </div>
                <div class="overflow-hidden">
                  <p class="text-xs md:text-sm text-foreground-muted font-medium mb-0.5">{contactData.sidebar.contact.email.label}</p>
                  <p class="font-bold text-foreground truncate">{contactData.sidebar.contact.email.value}</p>
                </div>
              </a>
              
              <a href={`https://x.com/${contactData.sidebar.contact.twitter.value.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-4 rounded-2xl border border-border hover:border-brand-500/40 hover:bg-secondary/10 transition-all group shadow-sm">
                <div class="w-12 h-12 bg-secondary rounded-xl flex items-center justify-center group-hover:bg-brand-500/10 transition-colors shrink-0">
                  <Icon name="twitter" class="w-5 h-5 text-foreground-muted group-hover:text-brand-500" />
                </div>
                <div>
                  <p class="text-xs md:text-sm text-foreground-muted font-medium mb-0.5">{contactData.sidebar.contact.twitter.label}</p>
                  <p class="font-bold text-foreground">{contactData.sidebar.contact.twitter.value}</p>
                </div>
              </a>
            </div>
          </div>

          <div class="bg-secondary/20 p-6 md:p-8 rounded-3xl border border-border shadow-sm">
            <h3 class="text-lg font-bold mb-5 flex items-center gap-2 text-foreground">
              <div class="w-8 h-8 rounded-lg bg-background border border-border flex items-center justify-center shrink-0 shadow-sm">
                <Icon name="info" class="w-4 h-4 text-brand-500" />
              </div>
              {contactData.sidebar.rules.title}
            </h3>
            <ul class="space-y-4 text-sm text-foreground-muted leading-relaxed">
              {contactData.sidebar.rules.items.map((rule: any, idx: number) => (
                <li class="flex items-start gap-3 bg-background/50 p-3 rounded-xl border border-border/50">
                  <Icon name={ruleStyles[idx].icon} class={`w-4 h-4 shrink-0 mt-0.5 ${ruleStyles[idx].color}`} />
                  <span><strong class="text-foreground">{rule.bold}</strong>{rule.text}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>

      </div>
    </div>
  </section>
</PageLayout>