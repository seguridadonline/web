---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getLocaleFromPath } from '@/i18n/config';
import { es } from '@/i18n/translations/es.ts';
import { en } from '@/i18n/translations/en.ts';
import { fr } from '@/i18n/translations/fr.ts';

const locale = getLocaleFromPath(Astro.url.pathname);
const dictionaries: Record<string, any> = { es, en, fr };
const currentLang = dictionaries[locale] || dictionaries.es;

const auditData = currentLang.audit;
---

<PageLayout
  title={auditData.meta.title}
  description={auditData.meta.description}
>
  <section class="relative pt-12 pb-16 md:pt-20 md:pb-24 overflow-hidden border-b border-border bg-secondary/5">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-[30rem] h-[30rem] bg-red-500/5 rounded-full blur-[100px] -z-10"></div>
    
    <div class="container mx-auto px-6 text-center z-10 relative max-w-4xl">
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-500/10 text-red-600 dark:text-red-400 text-sm font-semibold border border-red-500/20 shadow-sm">
          <Icon name="shield-alert" class="w-4 h-4" />
          {auditData.hero.badge}
        </div>
      </div>
      
      <h1 class="text-3xl font-extrabold tracking-tight md:text-5xl lg:text-[3.25rem] leading-tight text-foreground mb-6">
        {auditData.hero.title}
      </h1>
      
      <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto" set:html={auditData.hero.description}></p>
    </div>
  </section>

  <section class="py-12 bg-background border-b border-border">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="flex flex-col md:flex-row gap-5 items-start p-6 md:p-8 bg-brand-500/5 border border-brand-500/20 rounded-2xl shadow-sm relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1.5 h-full bg-brand-500"></div>
        <div class="w-10 h-10 rounded-full bg-brand-500/10 flex items-center justify-center shrink-0">
          <Icon name="mail-warning" class="w-5 h-5 text-brand-500" />
        </div>
        <div>
          <h3 class="text-lg md:text-xl font-bold mb-2 text-foreground">{auditData.notice.title}</h3>
          <p class="text-foreground-muted leading-relaxed text-sm md:text-base" set:html={auditData.notice.description}></p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-secondary/10">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-10 text-foreground text-center md:text-left">
        {auditData.protocol.title}
      </h2>
      
      <div class="space-y-6">
        
        <div class="bg-background p-6 md:p-8 rounded-2xl border border-border shadow-sm hover:border-brand-500/30 transition-colors">
          <h3 class="text-lg md:text-xl font-bold mb-4 flex items-center gap-3 text-foreground">
            <div class="w-10 h-10 rounded-xl bg-secondary flex items-center justify-center shrink-0">
              <Icon name="file-search" class="w-5 h-5 text-foreground-muted" />
            </div>
            {auditData.protocol.reason.title}
          </h3>
          <p class="text-foreground-muted leading-relaxed md:ml-13" set:html={auditData.protocol.reason.description}></p>
        </div>

        <div class="bg-background p-6 md:p-8 rounded-2xl border border-border shadow-sm hover:border-brand-500/30 transition-colors">
          <h3 class="text-lg md:text-xl font-bold mb-4 flex items-center gap-3 text-foreground">
            <div class="w-10 h-10 rounded-xl bg-secondary flex items-center justify-center shrink-0">
              <Icon name="clock" class="w-5 h-5 text-foreground-muted" />
            </div>
            {auditData.protocol.deadlines.title}
          </h3>
          <div class="md:ml-13">
            <p class="text-foreground-muted leading-relaxed mb-4">{auditData.protocol.deadlines.description}</p>
            <ul class="list-disc list-inside text-foreground-muted space-y-2 mb-6">
              <li set:html={auditData.protocol.deadlines.standard}></li>
              <li set:html={auditData.protocol.deadlines.severe}></li>
            </ul>
            <div class="flex items-start gap-3 bg-secondary/30 p-4 rounded-xl border border-border">
              <Icon name="info" class="w-5 h-5 text-foreground-muted shrink-0 mt-0.5" />
              <p class="text-sm font-mono text-foreground-muted">
                {auditData.protocol.deadlines.note}
              </p>
            </div>
          </div>
        </div>

        <div class="bg-red-500/5 p-6 md:p-8 rounded-2xl border border-red-500/20 shadow-sm relative overflow-hidden transition-colors hover:border-red-500/40">
          <h3 class="text-lg md:text-xl font-bold mb-4 flex items-center gap-3 text-red-600 dark:text-red-400">
            <div class="w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center shrink-0">
              <Icon name="gavel" class="w-5 h-5 text-red-600 dark:text-red-400" />
            </div>
            {auditData.protocol.consequences.title}
          </h3>
          <p class="text-foreground-muted leading-relaxed md:ml-13" set:html={auditData.protocol.consequences.description}></p>
        </div>

        <div class="bg-background p-6 md:p-8 rounded-2xl border border-border shadow-sm hover:border-brand-500/30 transition-colors">
          <h3 class="text-lg md:text-xl font-bold mb-4 flex items-center gap-3 text-foreground">
            <div class="w-10 h-10 rounded-xl bg-secondary flex items-center justify-center shrink-0">
              <Icon name="scale" class="w-5 h-5 text-foreground-muted" />
            </div>
            {auditData.protocol.appeal.title}
          </h3>
          <div class="md:ml-13">
            <p class="text-foreground-muted leading-relaxed mb-6">{auditData.protocol.appeal.description}</p>
            
            <div class="bg-secondary/20 rounded-xl p-5 border border-border mb-6">
              <p class="text-foreground font-semibold mb-3 flex items-center gap-2">
                <Icon name="list-checks" class="w-4 h-4 text-brand-500" />
                {auditData.protocol.appeal.procedureLabel}
              </p>
              <ol class="list-decimal list-inside text-foreground-muted space-y-3">
                {auditData.protocol.appeal.steps.map((step: string) => (
                  <li class="pl-2 marker:text-foreground-muted marker:font-semibold" set:html={step}></li>
                ))}
              </ol>
            </div>

            <div class="flex items-start gap-3 bg-brand-500/5 p-4 rounded-xl border border-brand-500/20">
              <Icon name="shield-check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <p class="text-sm text-foreground-muted leading-relaxed">
                {auditData.protocol.appeal.note}
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</PageLayout>