---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getLocaleFromPath } from '@/i18n/config';
import { es } from '@/i18n/translations/es.ts';
import { en } from '@/i18n/translations/en.ts';
import { fr } from '@/i18n/translations/fr.ts';

const locale = getLocaleFromPath(Astro.url.pathname);
const dictionaries: Record<string, any> = { es, en, fr };
const currentLang = dictionaries[locale] || dictionaries.es;

const cookiesData = currentLang.cookies;

const sectionIcons = [
  "cookie",
  "server",
  "monitor",
  "shield-ban",
  "settings",
  "mail"
];
---

<PageLayout
  title={cookiesData.meta.title}
  description={cookiesData.meta.description}
>
  <section class="relative pt-12 pb-16 md:pt-20 md:pb-24 overflow-hidden border-b border-border bg-secondary/5">
    <div class="absolute bottom-0 right-1/4 w-[30rem] h-[30rem] bg-brand-500/5 rounded-full blur-[100px] -z-10"></div>
    
    <div class="container mx-auto px-6 text-center z-10 relative max-w-3xl">
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-secondary text-foreground text-sm font-semibold border border-border shadow-sm">
          <Icon name="cookie" class="w-4 h-4 text-brand-500" />
          {cookiesData.hero.badge}
        </div>
      </div>
      
      <h1 class="text-3xl font-extrabold tracking-tight md:text-5xl lg:text-[3.25rem] leading-tight text-foreground mb-4">
        {cookiesData.hero.title}
      </h1>
      
      <p class="text-sm font-mono text-brand-600 dark:text-brand-400 mb-6">
        {cookiesData.hero.lastUpdated}
      </p>
      
      <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto">
        {cookiesData.hero.description}
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-6 max-w-3xl space-y-8">
      
      {cookiesData.sections.map((section: any, idx: number) => (
        <div class="bg-background rounded-3xl p-6 md:p-8 border border-border shadow-sm hover:border-brand-500/30 transition-all">
          
          <h2 class="text-lg md:text-xl font-bold mb-4 flex items-center gap-3 text-foreground">
            <div class="w-10 h-10 rounded-xl bg-secondary flex items-center justify-center shrink-0">
              <Icon name={sectionIcons[idx]} class="w-5 h-5 text-foreground-muted" />
            </div>
            {section.title}
          </h2>
          
          <div class="text-foreground-muted leading-relaxed text-base md:text-lg md:ml-13">
            <span set:html={section.content}></span>

            {section.noList && (
              <div class="mt-6 space-y-4 bg-red-500/5 border border-red-500/20 rounded-2xl p-5 md:p-6 transition-colors hover:border-red-500/30">
                {section.noList.map((item: string) => (
                  <div class="flex items-start gap-3">
                    <Icon name="x-circle" class="w-5 h-5 text-red-500 shrink-0 mt-0.5" />
                    <p class="text-foreground text-sm md:text-base leading-relaxed">{item}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
          
        </div>
      ))}
      
    </div>
  </section>
</PageLayout>