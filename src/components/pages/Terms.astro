---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getLocaleFromPath } from '@/i18n/config';
import { es } from '@/i18n/translations/es.ts';
import { en } from '@/i18n/translations/en.ts';
import { fr } from '@/i18n/translations/fr.ts';

const locale = getLocaleFromPath(Astro.url.pathname);
const dictionaries: Record<string, any> = { es, en, fr };
const currentLang = dictionaries[locale] || dictionaries.es;

const termsData = currentLang.terms;
---

<PageLayout
  title={termsData.meta.title}
  description={termsData.meta.description}
>
  <section class="relative pt-12 pb-16 md:pt-20 md:pb-24 overflow-hidden border-b border-border bg-secondary/5">
    <div class="absolute top-0 left-1/4 w-[30rem] h-[30rem] bg-brand-500/5 rounded-full blur-[100px] -z-10"></div>
    
    <div class="container mx-auto px-6 text-center z-10 relative max-w-3xl">
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-secondary text-foreground text-sm font-semibold border border-border shadow-sm">
          <Icon name="scale" class="w-4 h-4 text-brand-500" />
          {termsData.hero.badge}
        </div>
      </div>
      
      <h1 class="text-3xl font-extrabold tracking-tight md:text-5xl lg:text-[3.25rem] leading-tight text-foreground mb-4">
        {termsData.hero.title}
      </h1>
      
      <p class="text-sm font-mono text-brand-600 dark:text-brand-400 mb-6">
        {termsData.hero.lastUpdated}
      </p>
      
      <p class="text-lg md:text-xl text-foreground-muted leading-relaxed max-w-3xl mx-auto">
        {termsData.hero.description}
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-6 max-w-3xl space-y-12 md:space-y-16">
      
      {termsData.sections.map((section: any) => (
        <div class="border-b border-border pb-12 md:pb-16 last:border-0 last:pb-0">
          
          <h2 class="text-xl md:text-2xl font-bold mb-6 text-foreground">
            {section.title}
          </h2>
          
          <div class="text-foreground-muted leading-relaxed text-base md:text-lg">
            <span set:html={section.content}></span>
          </div>

          {section.steps && (
            <div class="mt-8 md:mt-10 ml-2 md:ml-4 relative border-l-2 border-brand-500/20 pl-6 md:pl-8 space-y-8">
              {section.steps.map((step: any, index: number) => (
                <div class="relative bg-background p-5 md:p-6 rounded-2xl border border-border shadow-sm hover:border-brand-500/30 transition-colors">
                  <div class="absolute -left-[35px] md:-left-[43px] top-6 w-4 h-4 rounded-full bg-background border-2 border-brand-500 shadow-sm ring-4 ring-background"></div>
                  
                  <h3 class="text-base md:text-lg font-bold text-foreground mb-2 flex items-center gap-2">
                    {step.name}
                  </h3>
                  <p class="text-foreground-muted text-sm md:text-base leading-relaxed">
                    {step.desc}
                  </p>
                </div>
              ))}
            </div>
          )}
          
        </div>
      ))}
      
    </div>
  </section>
</PageLayout>