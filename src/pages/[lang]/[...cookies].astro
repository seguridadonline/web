---
import Cookies from '@/components/pages/Cookies.astro';
import { routes, footerRoutes } from '@/i18n/routes';

export function getStaticPaths() {
  const locales = ['en', 'fr'];
  
  const allRoutes = { ...routes, ...footerRoutes };

  return locales.map((locale) => {
    return {
      params: { 
        lang: locale, 
        cookies: allRoutes.cookies[locale] 
      },
      props: { lang: locale }
    };
  });
}

const { lang } = Astro.props;
---
<Cookies lang={lang} />