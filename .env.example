# -----------------------------------------------------------------------------
# Configuración Principal
# -----------------------------------------------------------------------------
SITE_URL=https://seguridadonline.org

# -----------------------------------------------------------------------------
# Form Handling (Resend)
# -----------------------------------------------------------------------------
# Aquí pegas tu API Key de Resend (la obtienes en el dashboard de Resend)
RESEND_API_KEY=re_tu_api_key_aqui

# El correo desde el cual saldrán los reportes. 
# IMPORTANTE: Este dominio debe estar verificado en Resend para que no llegue a spam.
RESEND_FROM_EMAIL=reportes@seguridadonline.org

# -----------------------------------------------------------------------------
# Verificación (Opcional pero recomendado para SEO)
# -----------------------------------------------------------------------------
# Esto ayuda a que Google indexe tu sitio como una entidad seria rápidamente
# GOOGLE_SITE_VERIFICATION=tu_codigo_aqui